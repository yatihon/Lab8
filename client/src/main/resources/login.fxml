<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="me.tihon.controller.LoginController"
      spacing="15" alignment="CENTER">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <Label fx:id="titleLabel" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <TextField  fx:id="usernameField"/>
    <PasswordField fx:id="passwordField"/>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="loginB"    onAction="#login"/>
        <Button fx:id="registerB" onAction="#register"/>
    </HBox>

    <Label fx:id="statusLabel" style="-fx-text-fill: red;"/>

    <Separator/>

    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="langLabel"/>
        <ComboBox fx:id="langBox" prefWidth="140"/>
    </HBox>

</VBox>