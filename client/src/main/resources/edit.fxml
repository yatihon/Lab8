<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="me.tihon.controller.EditController"
      spacing="10"
      style="-fx-background-color: #1e1e2e; -fx-min-width: 340;">

    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="120" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Name" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="label-muted"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="X" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="label-muted"/>
        <TextField fx:id="xField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Y" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="label-muted"/>
        <TextField fx:id="yField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Impact Speed" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="label-muted"/>
        <TextField fx:id="impactField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Soundtrack" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="label-muted"/>
        <TextField fx:id="soundtrackField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Minutes" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="label-muted"/>
        <TextField fx:id="minutesField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Weapon" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="label-muted"/>
        <ComboBox fx:id="weaponBox" GridPane.rowIndex="6" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <CheckBox fx:id="realHeroBox" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
        <CheckBox fx:id="toothpickBox" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
        <CheckBox fx:id="carCoolBox" GridPane.rowIndex="9" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="saveBtn" onAction="#save" styleClass="button-accent" prefWidth="120"/>
        <Button fx:id="cancelBtn" onAction="#cancel" styleClass="button-danger" prefWidth="120"/>
    </HBox>

</VBox>